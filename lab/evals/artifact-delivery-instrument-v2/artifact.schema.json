{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synaplex.ai/lab/artifact-delivery-instrument-v2/artifact.schema.json",
  "title": "Lossless sealed run manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "study_id", "run_id", "state", "samples", "raw_objects", "archive_acknowledgements", "manifest_sha256"],
  "properties": {
    "schema_version": {"const": 1},
    "study_id": {"const": "artifact-delivery-instrument-v2"},
    "run_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "state": {"enum": ["aborted", "sealed_complete"]},
    "samples": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/sample"}},
    "raw_objects": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/object"}},
    "archive_acknowledgements": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/ack"}},
    "manifest_sha256": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "object": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "relative_uri", "media_type", "byte_length", "sha256"],
      "properties": {
        "kind": {"enum": ["response_bytes", "response_headers", "timing", "dom_snapshot", "event_stream", "console_stream", "page_error_stream", "network_stream", "screenshot", "identity_proof", "clock_samples", "tool_versions", "exit_status"]},
        "relative_uri": {"type": "string", "minLength": 1},
        "media_type": {"type": "string", "minLength": 1},
        "byte_length": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/hash"}
      }
    },
    "ack": {
      "type": "object", "additionalProperties": false,
      "required": ["relative_uri", "byte_length", "sha256", "archived_at"],
      "properties": {
        "relative_uri": {"type": "string", "minLength": 1},
        "byte_length": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/hash"},
        "archived_at": {"type": "string", "format": "date-time"}
      }
    },
    "sample": {
      "type": "object", "additionalProperties": false,
      "required": ["sample_id", "identity_sha256", "anchor_offset_ns", "start_lateness_ns", "state", "classification", "assertions", "raw_object_hashes"],
      "properties": {
        "sample_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "identity_sha256": {"$ref": "#/$defs/hash"},
        "anchor_offset_ns": {"enum": [0, 30000000000, 60000000000]},
        "start_lateness_ns": {"type": "integer", "minimum": 0, "maximum": 250000000},
        "state": {"const": "complete"},
        "classification": {"enum": ["PASS", "TRANSPORT_FAILURE", "BEHAVIOR_FAILURE"]},
        "assertions": {"type": "array", "minItems": 1, "items": {"type": "object"}},
        "raw_object_hashes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/hash"}}
      }
    }
  }
}

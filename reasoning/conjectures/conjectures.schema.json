{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synaplex.ai/knowledge/conjectures.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "epistemic_status", "conjectures"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "epistemic_status": {"const": "conjectural"},
    "conjectures": {"type": "array", "items": {"$ref": "#/$defs/conjecture"}}
  },
  "$defs": {
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "strings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "conjecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "source_ids", "source_mechanism", "target_mechanism", "analogy_map", "disanalogies", "competing_explanations", "falsifiers", "preconditions", "expected_information_gain", "observation_route", "diversity_score", "novelty_score", "redundancy_score", "source_quality_score"],
      "properties": {
        "id": {"type": "string", "pattern": "^conj:[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "title": {"type": "string", "minLength": 1},
        "source_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "pattern": "^src:[a-f0-9]{16}$"}},
        "source_mechanism": {"type": "string", "minLength": 1},
        "target_mechanism": {"type": "string", "minLength": 1},
        "analogy_map": {"$ref": "#/$defs/strings"},
        "disanalogies": {"$ref": "#/$defs/strings"},
        "competing_explanations": {"$ref": "#/$defs/strings"},
        "falsifiers": {"$ref": "#/$defs/strings"},
        "preconditions": {"$ref": "#/$defs/strings"},
        "expected_information_gain": {"type": "string", "minLength": 1},
        "observation_route": {"type": "string", "pattern": "preregistered Claim"},
        "diversity_score": {"$ref": "#/$defs/score"},
        "novelty_score": {"$ref": "#/$defs/score"},
        "redundancy_score": {"$ref": "#/$defs/score"},
        "source_quality_score": {"$ref": "#/$defs/score"}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synaplex.ai/knowledge/engineering-cases.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cases"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "cases": {"type": "array", "items": {"$ref": "#/$defs/case"}}
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "title", "summary", "label", "status", "learned", "limits", "source_links"],
      "properties": {
        "id": {"type": "string", "pattern": "^case:[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "label": {"const": "engineering case study"},
        "status": {"const": "operational"},
        "learned": {"type": "string", "minLength": 1},
        "limits": {"type": "string", "minLength": 1},
        "source_links": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "format": "uri", "pattern": "^https://"}}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synaplex.ai/knowledge/public-projection.schema.json",
  "title": "Synaplex public knowledge projection",
  "type": "object",
  "additionalProperties": false,
  "required": ["projection_version", "generated_at", "digest", "counts", "research", "findings", "mechanisms", "engineering_cases", "sources", "conjectures"],
  "properties": {
    "projection_version": {"const": "1.1.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "counts": {
      "type": "object", "additionalProperties": false,
      "required": ["research", "findings", "mechanisms", "engineering_cases", "sources", "conjectures"],
      "properties": {
        "research": {"type": "integer", "minimum": 0}, "findings": {"type": "integer", "minimum": 0},
        "mechanisms": {"type": "integer", "minimum": 0}, "engineering_cases": {"type": "integer", "minimum": 0},
        "sources": {"type": "integer", "minimum": 0}, "conjectures": {"type": "integer", "minimum": 0}
      }
    },
    "research": {"type": "array", "items": {"$ref": "#/$defs/research"}},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "mechanisms": {"type": "array", "items": {"$ref": "#/$defs/mechanism"}},
    "engineering_cases": {"type": "array", "items": {"$ref": "#/$defs/engineering_case"}},
    "sources": {"type": "array", "items": {"$ref": "#/$defs/source"}},
    "conjectures": {"type": "array", "items": {"$ref": "#/$defs/conjecture"}}
  },
  "$defs": {
    "strings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance": {"type": "object", "additionalProperties": false, "required": ["claim_id", "decision_id", "evidence_ids"], "properties": {"claim_id": {"type": "string"}, "decision_id": {"type": ["string", "null"]}, "evidence_ids": {"type": "array", "items": {"type": "string"}}}},
    "block": {"type": "object", "additionalProperties": false, "required": ["code", "since", "summary", "source_digest"], "properties": {"code": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "since": {"type": "string", "format": "date-time"}, "summary": {"type": "string", "minLength": 1}, "source_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}},
    "research": {"type": "object", "additionalProperties": false, "required": ["id", "slug", "title", "summary", "status", "validity", "registered_at", "updated_at", "superseded_by", "public_artifact", "provenance"], "properties": {"id": {"type": "string"}, "slug": {"type": "string"}, "title": {"type": "string"}, "summary": {"type": "string"}, "status": {"enum": ["active", "blocked", "completed", "invalidated", "withdrawn", "superseded"]}, "validity": {"enum": ["pending", "valid", "invalid", "withdrawn", "superseded"]}, "registered_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}, "superseded_by": {"type": ["string", "null"]}, "public_artifact": {"type": "string", "pattern": "^/"}, "block": {"$ref": "#/$defs/block"}, "provenance": {"$ref": "#/$defs/provenance"}}},
    "finding": {"type": "object", "additionalProperties": false, "required": ["id", "claim_id", "decision_id", "evidence_ids", "statement", "validity", "decided_at", "superseded_by"], "properties": {"id": {"type": "string"}, "claim_id": {"type": "string"}, "decision_id": {"type": "string"}, "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "statement": {"type": "string"}, "validity": {"const": "valid"}, "decided_at": {"type": "string", "format": "date-time"}, "superseded_by": {"type": ["string", "null"]}}},
    "mechanism": {"type": "object", "additionalProperties": false, "required": ["id", "title", "summary", "status", "public_artifact"], "properties": {"id": {"type": "string"}, "title": {"type": "string"}, "summary": {"type": "string"}, "status": {"type": "string"}, "public_artifact": {"type": "string", "pattern": "^/"}}},
    "engineering_case": {"type": "object", "additionalProperties": false, "required": ["id", "slug", "title", "summary", "label", "status", "learned", "limits", "source_links"], "properties": {"id": {"type": "string"}, "slug": {"type": "string"}, "title": {"type": "string"}, "summary": {"type": "string"}, "label": {"const": "engineering case study"}, "status": {"const": "operational"}, "learned": {"type": "string"}, "limits": {"type": "string"}, "source_links": {"type": "array", "minItems": 1, "items": {"type": "string", "format": "uri", "pattern": "^https://"}}}},
    "source": {"type": "object", "additionalProperties": false, "required": ["id", "title", "url", "retrieved_at", "source_class", "domain", "author_publisher", "content_digest", "access_license", "quality"], "properties": {"id": {"type": "string", "pattern": "^src:[a-f0-9]{16}$"}, "title": {"type": "string"}, "url": {"type": "string", "format": "uri", "pattern": "^https://"}, "retrieved_at": {"type": "string", "format": "date-time"}, "source_class": {"type": "string"}, "domain": {"type": "string"}, "author_publisher": {"type": "string"}, "content_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "access_license": {"type": "string"}, "quality": {"$ref": "#/$defs/score"}}},
    "conjecture": {"type": "object", "additionalProperties": false, "required": ["id", "title", "source_ids", "source_mechanism", "target_mechanism", "analogy_map", "disanalogies", "competing_explanations", "falsifiers", "preconditions", "expected_information_gain", "observation_route", "diversity_score", "novelty_score", "redundancy_score", "source_quality_score"], "properties": {"id": {"type": "string"}, "title": {"type": "string"}, "source_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "pattern": "^src:[a-f0-9]{16}$"}}, "source_mechanism": {"type": "string"}, "target_mechanism": {"type": "string"}, "analogy_map": {"$ref": "#/$defs/strings"}, "disanalogies": {"$ref": "#/$defs/strings"}, "competing_explanations": {"$ref": "#/$defs/strings"}, "falsifiers": {"$ref": "#/$defs/strings"}, "preconditions": {"$ref": "#/$defs/strings"}, "expected_information_gain": {"type": "string"}, "observation_route": {"type": "string", "pattern": "preregistered Claim"}, "diversity_score": {"$ref": "#/$defs/score"}, "novelty_score": {"$ref": "#/$defs/score"}, "redundancy_score": {"$ref": "#/$defs/score"}, "source_quality_score": {"$ref": "#/$defs/score"}}}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synaplex.ai/knowledge/public-projection.schema.json",
  "title": "Synaplex public knowledge projection",
  "type": "object",
  "additionalProperties": false,
  "required": ["projection_version", "generated_at", "digest", "counts", "research", "findings", "mechanisms"],
  "properties": {
    "projection_version": {"const": "1.0.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research", "findings", "mechanisms"],
      "properties": {"research": {"type": "integer"}, "findings": {"type": "integer"}, "mechanisms": {"type": "integer"}}
    },
    "research": {"type": "array", "items": {"$ref": "#/$defs/research"}},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "mechanisms": {"type": "array", "items": {"$ref": "#/$defs/mechanism"}}
  },
  "$defs": {
    "provenance": {"type": "object", "additionalProperties": false, "required": ["claim_id", "decision_id", "evidence_ids"], "properties": {"claim_id": {"type": "string"}, "decision_id": {"type": ["string", "null"]}, "evidence_ids": {"type": "array", "items": {"type": "string"}}}},
    "block": {"type": "object", "additionalProperties": false, "required": ["code", "since", "summary", "source_digest"], "properties": {"code": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "since": {"type": "string", "format": "date-time"}, "summary": {"type": "string", "minLength": 1}, "source_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}},
    "research": {"type": "object", "additionalProperties": false, "required": ["id", "slug", "title", "summary", "status", "validity", "registered_at", "updated_at", "superseded_by", "public_artifact", "provenance"], "properties": {"id": {"type": "string"}, "slug": {"type": "string"}, "title": {"type": "string"}, "summary": {"type": "string"}, "status": {"enum": ["active", "blocked", "completed", "invalidated", "withdrawn", "superseded"]}, "validity": {"enum": ["pending", "valid", "invalid", "withdrawn", "superseded"]}, "registered_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}, "superseded_by": {"type": ["string", "null"]}, "public_artifact": {"type": "string", "pattern": "^/"}, "block": {"$ref": "#/$defs/block"}, "provenance": {"$ref": "#/$defs/provenance"}}},
    "finding": {"type": "object", "additionalProperties": false, "required": ["id", "claim_id", "decision_id", "evidence_ids", "statement", "validity", "decided_at", "superseded_by"], "properties": {"id": {"type": "string"}, "claim_id": {"type": "string"}, "decision_id": {"type": "string"}, "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "statement": {"type": "string"}, "validity": {"const": "valid"}, "decided_at": {"type": "string"}, "superseded_by": {"type": ["string", "null"]}}},
    "mechanism": {"type": "object", "additionalProperties": false, "required": ["id", "title", "summary", "status", "public_artifact"], "properties": {"id": {"type": "string"}, "title": {"type": "string"}, "summary": {"type": "string"}, "status": {"type": "string"}, "public_artifact": {"type": "string", "pattern": "^/"}}}
  }
}

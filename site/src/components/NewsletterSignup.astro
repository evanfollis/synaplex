---
// Buttondown embed — replace BUTTONDOWN_USERNAME at first deploy.
// The form POSTs directly to Buttondown, so no backend is required.
const buttondownUser = import.meta.env.PUBLIC_BUTTONDOWN_USER || 'agentstack';
---

<div class="border border-gray-200 bg-white rounded-md p-6 my-8">
  <h3 class="text-lg font-semibold mb-1">Get the weekly synthesis</h3>
  <p class="text-sm mb-4" style="color: var(--color-ink-dim);">
    One long-form post every Friday on the architecture of agent platforms.
    Daily news scan opt-in after signup.
  </p>
  <form
    action={`https://buttondown.com/api/emails/embed-subscribe/${buttondownUser}`}
    method="post"
    target="popupwindow"
    onsubmit={`window.open('https://buttondown.com/${buttondownUser}', 'popupwindow')`}
    class="flex flex-col sm:flex-row gap-2"
  >
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
      class="flex-1 px-3 py-2 border border-gray-300 rounded text-sm"
    />
    <input type="hidden" name="embed" value="1" />
    <button
      type="submit"
      class="px-4 py-2 text-white rounded text-sm font-medium"
      style="background: var(--color-accent);"
    >
      Subscribe
    </button>
  </form>
  <p class="text-xs mt-3" style="color: var(--color-ink-dim);">
    No spam, one Friday email. Unsubscribe any time.
  </p>
</div>

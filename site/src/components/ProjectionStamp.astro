---
import projection from '../data/public-projection.json';
const shortDigest = projection.digest.replace('sha256:', '').slice(0, 12);
---
<div class="projection-stamp" aria-label="Public projection provenance">
  <span>Projection v{projection.projection_version}</span>
  <span aria-hidden="true">/</span>
  <span title={projection.digest}>digest {shortDigest}</span>
</div>

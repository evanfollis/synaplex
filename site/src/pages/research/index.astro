---
import Layout from '../../layouts/Layout.astro'; import Status from '../../components/Status.astro'; import projection from '../../data/public-projection.json';
---
<Layout title="Research" description="Every public research record, including blocked, invalidated, and withdrawn work.">
  <p class="eyebrow">Research</p><h1>The full record, not a highlight reel.</h1><p class="lede">Every preregistered Claim is accounted for. Status comes from canon Decisions plus the reviewed public projection metadata.</p>
  <div class="section record-list">{projection.research.map((item) => <a class="record" href={`/research/${item.slug}/`}><Status value={item.status}/><div><h3>{item.title}</h3><p>{item.summary}</p></div><span aria-hidden="true">→</span></a>)}</div>
</Layout>

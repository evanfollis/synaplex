---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Directory" description="Quality-graded directory of AI-system components, grown from the lab's evaluation corpus.">
  <h1 class="text-3xl font-bold mb-4 tracking-tight">Directory</h1>
  <p class="text-lg mb-8 max-w-2xl" style="color: var(--color-ink-dim);">
    A quality-graded catalog of AI-system components — agent harnesses,
    memory systems, orchestration frameworks, integration layers — built from
    the lab's accumulated evaluation corpus, not from star counts. Listings
    emerge as evaluations produce auditable evidence.
  </p>

  <p style="color: var(--color-ink-dim);" class="italic">
    Coming soon.
  </p>
</Layout>
